{
  "name": "@promptwright/cli",
  "version": "0.0.1",
  "description": "Promptwright Command Line Interface",
  "main": "./dist/index.js",
  "type": "module",
  "bin": {
    "promptwright": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
